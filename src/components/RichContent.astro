---
import type { RichBlock } from "../lib/portal-content";

type Props = {
  blocks: RichBlock[];
  base: string;
};

const { blocks, base } = Astro.props;
const isExternal = (href: string) => /^(https?:|mailto:|#)/.test(href);
const withBase = (path = "") => `${base}${path.replace(/^\/+/, "")}`;
---

<div class="rich-content" data-rich-content>
  {
    blocks.map((block) => {
      if (block.type === "paragraph") {
        return <p data-content-block data-block-id={block.id} data-block-type={block.type}>{block.text}</p>;
      }
      if (block.type === "heading") {
        return block.level === 3 ? (
          <h3 data-content-block data-block-id={block.id} data-block-type={block.type}>{block.text}</h3>
        ) : (
          <h2 data-content-block data-block-id={block.id} data-block-type={block.type}>{block.text}</h2>
        );
      }
      if (block.type === "image") {
        return (
          <figure class={`rich-image rich-image--${block.width || "normal"}`} data-content-block data-block-id={block.id} data-block-type={block.type}>
            <img src={isExternal(block.src) ? block.src : withBase(block.src)} alt={block.alt} loading="lazy" />
            {block.caption && <figcaption>{block.caption}</figcaption>}
          </figure>
        );
      }
      if (block.type === "list") {
        const ListTag = block.style === "ordered" ? "ol" : "ul";
        return (
          <ListTag class={block.style === "todo" ? "todo-list" : undefined} data-content-block data-block-id={block.id} data-block-type={block.type}>
            {block.items.map((item) => <li>{item}</li>)}
          </ListTag>
        );
      }
      if (block.type === "link") {
        return (
          <p data-content-block data-block-id={block.id} data-block-type={block.type}>
            <a class="rich-link-button" href={isExternal(block.href) ? block.href : withBase(block.href)}>{block.label}</a>
          </p>
        );
      }
      if (block.type === "quote") {
        return <blockquote data-content-block data-block-id={block.id} data-block-type={block.type}>{block.text}</blockquote>;
      }
      if (block.type === "divider") {
        return <hr data-content-block data-block-id={block.id} data-block-type={block.type} />;
      }
      return (
        <pre data-content-block data-block-id={block.id} data-block-type={block.type}><code class={block.language ? `language-${block.language}` : undefined}>{block.code}</code></pre>
      );
    })
  }
</div>
