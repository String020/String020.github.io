---
import { getCollection } from "astro:content";
import { site } from "../../data/site";
import { formatDate, getAllCategories, getAllSeries, getAllTags, getCategory, getImageUrl, getReadingStats, getSeries, isPublished, slugifyTaxonomy, sortPosts } from "../../lib/blog";
import "../../styles/global.css";
import "../../styles/blog-features.css";

const posts = sortPosts((await getCollection("blog")).filter(isPublished));
const tags = getAllTags(posts);
const categories = getAllCategories(posts);
const seriesList = getAllSeries(posts);

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => `${base}${path.replace(/^\/+/, "")}`;
const backgroundStyle = `--background-image: url("${withBase("assets/handwriting-bg.jpg")}")`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Blog archive for the personal portal." />
    <title>Blog | {site.brand.name}</title>
  </head>
  <body style={backgroundStyle}>
    <div class="backdrop" aria-hidden="true"></div>
    <div class="soft-wash" aria-hidden="true"></div>

    <main class="blog-shell panel">
      <a class="back-link" href={withBase()}>Back to portal</a>
      <header class="blog-header">
        <p>BLOG</p>
        <h1>All posts</h1>
        <span>Markdown files from <code>src/content/blog</code>.</span>
        <nav class="blog-tools" aria-label="Blog tools">
          <a class="tool-link" href={withBase("search/")}>Search</a>
          <a class="tool-link" href={withBase("blog/archive/")}>Archive</a>
          <a class="tool-link" href={withBase("blog/writing-guide/")}>Writing guide</a>
          <a class="tool-link" href={withBase("rss.xml")}>RSS</a>
          <a class="tool-link" href={withBase("sitemap.xml")}>Sitemap</a>
        </nav>
      </header>

      {categories.length > 0 && (
        <section class="taxonomy-block" aria-label="Categories">
          <h2>Categories</h2>
          <div class="taxonomy-cloud">
            {categories.map((category) => (
              <a class="taxonomy-link" href={withBase(`blog/category/${slugifyTaxonomy(category)}/`)}>{category}</a>
            ))}
          </div>
        </section>
      )}

      {seriesList.length > 0 && (
        <section class="taxonomy-block" aria-label="Series">
          <h2>Series</h2>
          <div class="taxonomy-cloud">
            {seriesList.map((series) => (
              <a class="taxonomy-link" href={withBase(`blog/series/${slugifyTaxonomy(series)}/`)}>{series}</a>
            ))}
          </div>
        </section>
      )}

      {tags.length > 0 && (
        <section class="taxonomy-block" aria-label="Tags">
          <h2>Tags</h2>
          <div class="taxonomy-cloud">
            {tags.map((tag) => (
              <a class="taxonomy-link" href={withBase(`blog/tag/${slugifyTaxonomy(tag)}/`)}>#{tag}</a>
            ))}
          </div>
        </section>
      )}

      <section class="blog-list" aria-label="Blog posts">
        {
          posts.map((post) => {
            const stats = getReadingStats(post);
            const category = getCategory(post);
            const series = getSeries(post);
            const image = getImageUrl(post, withBase);
            return (
              <article class={`blog-row ${image ? "has-cover" : ""}`}>
                {image && (
                  <a class="post-cover" href={withBase(`blog/${post.id}/`)} aria-label={post.data.title}>
                    <img src={image} alt="" loading="lazy" />
                  </a>
                )}
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                <div>
                  <div class="post-meta-line">
                    {post.data.pinned && <span class="pinned-badge">Pinned</span>}
                    <a class="post-category" href={withBase(`blog/category/${slugifyTaxonomy(category)}/`)}>{category}</a>
                    {series && <a class="meta-pill" href={withBase(`blog/series/${slugifyTaxonomy(series)}/`)}>{series}</a>}
                    <span class="meta-pill">{stats.label}</span>
                  </div>
                  <a class="post-title-link" href={withBase(`blog/${post.id}/`)}>
                    <h2>{post.data.title}</h2>
                  </a>
                  <p>{post.data.description}</p>
                  <div class="post-tags">
                    {post.data.tags.map((tag) => (
                      <a href={withBase(`blog/tag/${slugifyTaxonomy(tag)}/`)}>#{tag}</a>
                    ))}
                  </div>
                </div>
              </article>
            );
          })
        }
      </section>
    </main>
  </body>
</html>
