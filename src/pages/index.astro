---
import { getCollection } from "astro:content";
import { site } from "../data/site";
import "../styles/global.css";
import "../styles/blog-features.css";

const getPostDate = (post: { data: { published?: Date; date?: Date } }) =>
  post.data.published ?? post.data.date ?? new Date(0);
const blogPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const pinnedDelta = Number(b.data.pinned) - Number(a.data.pinned);
    if (pinnedDelta !== 0) return pinnedDelta;
    return getPostDate(b).valueOf() - getPostDate(a).valueOf();
  });

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => `${base}${path.replace(/^\/+/, "")}`;
const isExternal = (href: string) => /^(https?:|mailto:|#)/.test(href);
const linkHref = (href: string) => (isExternal(href) ? href : withBase(href));
const backgroundStyle = `--background-image: url("${withBase("assets/handwriting-bg.jpg")}")`;
const pageCount = site.nav.length;
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "2-digit" }).format(date);
const dashboardStats = site.dashboard.stats.map((stat) =>
  stat.label === "Blog posts" ? { ...stat, value: String(blogPosts.length).padStart(2, "0") } : stat,
);
const categories = Array.from(new Set(blogPosts.map((post) => post.data.category).filter(Boolean)));
const tagCounts = blogPosts.reduce((counts, post) => {
  post.data.tags.forEach((tag) => counts.set(tag, (counts.get(tag) ?? 0) + 1));
  return counts;
}, new Map<string, number>());
const topTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 8);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={site.description} />
    <title>{site.title}</title>
  </head>
  <body style={backgroundStyle}>
    <div class="backdrop" aria-hidden="true"></div>
    <div class="soft-wash" aria-hidden="true"></div>

    <header class="portal-header">
      <a class="portal-brand" href={withBase()} aria-label="Portal home">
        <span class="brand-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img">
            <path d="M12 2.8 20 6.2v5.9c0 4.8-3.4 7.8-8 9.1-4.6-1.3-8-4.3-8-9.1V6.2l8-3.4Z"></path>
            <path d="M8.4 10.4 12 7.8l3.6 2.6-1.4 4.2H9.8l-1.4-4.2Z"></path>
          </svg>
        </span>
        <span>{site.brand.name}</span>
      </a>

      <nav class="tabs" aria-label="Portal pages">
        {
          site.nav.map((item, index) => (
            <button class={`tab ${index === 0 ? "is-active" : ""}`} type="button" data-page={index}>
              {item}
            </button>
          ))
        }
        <button class="tool-button compact" type="button" aria-label="Filter">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7h9"></path>
            <path d="M17 7h3"></path>
            <path d="M15 5v4"></path>
            <path d="M4 17h3"></path>
            <path d="M11 17h9"></path>
            <path d="M9 15v4"></path>
          </svg>
        </button>
      </nav>

      <div class="header-actions" aria-label="Header actions">
        <a class="search-pill" href={withBase("search/")} aria-label="Search blog">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m20 20-4.3-4.3"></path>
            <circle cx="10.8" cy="10.8" r="6.2"></circle>
          </svg>
          <span>Search blog</span>
        </a>
        <button class="tool-button dot-grid" type="button" aria-label="Apps">
          <span></span><span></span><span></span>
          <span></span><span></span><span></span>
          <span></span><span></span><span></span>
        </button>
        <button class="tool-button" type="button" aria-label="Messages">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5.4 6.2h13.2a2 2 0 0 1 2 2v6.5a2 2 0 0 1-2 2h-6.1l-4.1 3v-3h-3a2 2 0 0 1-2-2V8.2a2 2 0 0 1 2-2Z"></path>
            <path d="M8 10.3h8"></path>
            <path d="M8 13.2h5.6"></path>
          </svg>
        </button>
        <button class="tool-button" type="button" aria-label="Profile">
          <span>{site.brand.initials}</span>
        </button>
      </div>
    </header>

    <main class="app-shell">
      <aside class="profile-column" aria-label="Profile panel">
        <section class="profile-card panel">
          <div class="avatar" aria-hidden="true">
            <span>{site.brand.initials}</span>
          </div>
          <h1>{site.profile.name}</h1>
          <p>{site.profile.summary}</p>
          <div class="quick-links" aria-label="Quick links">
            {site.profile.links.map((link) => <a href={linkHref(link.href)}>{link.label}</a>)}
          </div>
        </section>

        <section class="mini-card panel">
          <div class="mini-title">
            <span></span>
            Notice
          </div>
          <p>{site.profile.notice}</p>
        </section>

        <section class="mini-card panel">
          <div class="mini-title">
            <span></span>
            Tags
          </div>
          <div class="tag-cloud">
            {site.profile.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </section>
      </aside>

      <section class="content-stage panel" aria-live="polite">
        <div class="slide-track" data-track style={`--page-count: ${pageCount}`}>
          <article class="page is-current" data-panel="home">
            <div class="page-heading">
              <p>{site.dashboard.eyebrow}</p>
              <h2>{site.dashboard.title}</h2>
            </div>
            <div class="summary-row">
              {
                dashboardStats.map((stat, index) => (
                  <div class={`stat tone-${["a", "b", "c", "d"][index % 4]}`}>
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </div>
                ))
              }
            </div>
            <div class="home-grid">
              <section class="focus-panel">
                <h3>{site.dashboard.focus.title}</h3>
                <p>{site.dashboard.focus.text}</p>
                <div class="progress-line">
                  <span style={`width: ${site.dashboard.focus.progress}%`}></span>
                </div>
              </section>
              <section class="todo-panel">
                <h3>Next edits</h3>
                <ul>
                  {site.dashboard.today.map((item) => <li>{item}</li>)}
                </ul>
              </section>
            </div>
          </article>

          <article class="page" data-panel="blog">
            <div class="page-heading">
              <p>{site.blog.eyebrow}</p>
              <h2>{site.blog.title}</h2>
            </div>
            <div class="blog-panel-grid">
              <section class="note-card blog-preview-card">
                <h3>Latest posts</h3>
                <div class="blog-preview-list">
                  {
                    blogPosts.slice(0, 4).map((post) => (
                      <a class="blog-preview-link" href={withBase(`blog/${post.id}/`)}>
                        <span>{formatDate(getPostDate(post))}{post.data.pinned ? " / Pinned" : ""}</span>
                        <strong>{post.data.title}</strong>
                        <small>{post.data.description}</small>
                      </a>
                    ))
                  }
                </div>
              </section>
              <section class="note-card pale blog-help-card">
                <h3>Blog tools</h3>
                <p>{site.blog.intro}</p>
                <nav class="blog-tools" aria-label="Blog tools">
                  {site.blog.actions.map((action) => <a class="tool-link" href={linkHref(action.href)}>{action.label}</a>)}
                </nav>
              </section>
            </div>
          </article>

          <article class="page" data-panel="archive">
            <div class="page-heading">
              <p>{site.archive.eyebrow}</p>
              <h2>{site.archive.title}</h2>
            </div>
            <p class="page-intro">{site.archive.intro}</p>
            <div class="feature-grid">
              {
                site.archive.cards.map((card) => (
                  <a class="directory-card" href={linkHref(card.href)}>
                    <span>{card.badge}</span>
                    <h3>{card.title}</h3>
                    <p>{card.text}</p>
                  </a>
                ))
              }
            </div>
            <div class="metadata-row">
              <span>{categories.length || 0} categories</span>
              <span>{topTags.length || 0} active tags</span>
              <span>{blogPosts.length} published posts</span>
            </div>
          </article>

          <article class="page" data-panel="my">
            <div class="page-heading">
              <p>{site.mySpace.eyebrow}</p>
              <h2>{site.mySpace.title}</h2>
            </div>
            <div class="feature-grid">
              {
                site.mySpace.pages.map((page) => (
                  <a class="directory-card" href={withBase(`${page.slug}/`)}>
                    <span>{page.badge}</span>
                    <h3>{page.title}</h3>
                    <p>{page.text}</p>
                  </a>
                ))
              }
            </div>
          </article>

          <article class="page" data-panel="network">
            <div class="page-heading">
              <p>{site.network.eyebrow}</p>
              <h2>{site.network.title}</h2>
            </div>
            <div class="network-grid">
              <div class="feature-grid compact">
                {
                  site.network.pages.map((page) => (
                    <a class="directory-card" href={withBase(`${page.slug}/`)}>
                      <span>{page.badge}</span>
                      <h3>{page.title}</h3>
                      <p>{page.text}</p>
                    </a>
                  ))
                }
              </div>
              <div class="contact-grid">
                {
                  site.network.links.map((link) => (
                    <a href={linkHref(link.href)}>
                      <span>{link.label}</span>
                      {link.value}
                    </a>
                  ))
                }
              </div>
            </div>
          </article>

          <article class="page" data-panel="build">
            <div class="page-heading">
              <p>{site.build.eyebrow}</p>
              <h2>{site.build.title}</h2>
            </div>
            <div class="feature-grid build-pages">
              {
                site.build.pages.map((page) => (
                  <a class="directory-card" href={withBase(`${page.slug}/`)}>
                    <span>{page.badge}</span>
                    <h3>{page.title}</h3>
                    <p>{page.text}</p>
                  </a>
                ))
              }
            </div>
            <div class="compact-card-list">
              {
                site.build.projects.map((project, index) => (
                  <article class="project-item">
                    <span class={`project-icon tone-${["a", "b", "c"][index % 3]}`}>
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <div>
                      <h3>{project.title}</h3>
                      <p>{project.text}</p>
                    </div>
                    <a href={linkHref(project.href)}>View</a>
                  </article>
                ))
              }
            </div>
          </article>

          <article class="page" data-panel="system">
            <div class="page-heading">
              <p>{site.system.eyebrow}</p>
              <h2>{site.system.title}</h2>
            </div>
            <div class="status-grid">
              {
                site.system.features.map((feature) => (
                  <article class="status-card">
                    <span class={`status-pill ${feature.status}`}>{feature.status}</span>
                    <h3>{feature.title}</h3>
                    <p>{feature.text}</p>
                  </article>
                ))
              }
            </div>
            <section class="widget-card">
              <h3>Sidebar/widget map</h3>
              <div class="widget-cloud">
                {site.system.widgets.map((widget) => <span>{widget}</span>)}
              </div>
            </section>
          </article>
        </div>
      </section>
    </main>

    <script is:inline>
      const tabs = Array.from(document.querySelectorAll("[data-page]"));
      const track = document.querySelector("[data-track]");
      const panels = Array.from(document.querySelectorAll("[data-panel]"));
      const pageCount = panels.length || 1;

      track.style.setProperty("--page-count", String(pageCount));

      function setActivePage(index) {
        const pageIndex = Number(index);
        track.style.transform = `translateX(calc(-${pageIndex} * 100% / ${pageCount}))`;

        tabs.forEach((tab, currentIndex) => {
          const isActive = currentIndex === pageIndex;
          tab.classList.toggle("is-active", isActive);
          tab.setAttribute("aria-selected", String(isActive));
        });

        panels.forEach((panel, currentIndex) => {
          panel.classList.toggle("is-current", currentIndex === pageIndex);
        });
      }

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          setActivePage(tab.dataset.page);
        });
      });

      setActivePage(0);
    </script>
  </body>
</html>
