---
import { getCollection, render } from "astro:content";
import ManagedCardGrid from "../components/ManagedCardGrid.astro";
import RichContent from "../components/RichContent.astro";
import { site } from "../data/site";
import { managedNavigation, portalContent } from "../lib/portal-content";
import "../styles/global.css";
import "../styles/blog-features.css";

const getPostDate = (post: { data: { published?: Date; date?: Date } }) =>
  post.data.published ?? post.data.date ?? new Date(0);
const blogPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const pinnedDelta = Number(b.data.pinned) - Number(a.data.pinned);
    if (pinnedDelta !== 0) return pinnedDelta;
    return getPostDate(b).valueOf() - getPostDate(a).valueOf();
  });
const renderedBlogPosts = await Promise.all(
  blogPosts.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
  }),
);

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => `${base}${path.replace(/^\/+/, "")}`;
const isExternal = (href: string) => /^(https?:|mailto:|#)/.test(href);
const linkHref = (href: string) => (isExternal(href) ? href : withBase(href));
const tagHref = (tag: string) =>
  ({
    Blog: "blog/",
    Archives: "archives/",
    My: "my/",
    About: "about/",
    Projects: "projects/",
    Study: "blog/tag/notes/",
  })[tag] ?? `search/?q=${encodeURIComponent(tag)}`;
const backgroundStyle = `--background-image: url("${withBase("assets/handwriting-bg.jpg")}")`;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;
const navigation = portalContent.navigation;
const pageCount = navigation.length + portalContent.pages.length + renderedBlogPosts.length + 1;
const tabIndexByNavigationId = new Map(navigation.map((item, index) => [item.id, index]));
const editorScriptUrl = withBase("assets/portal-editor.js");
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL || "";
const serializedPortalContent = JSON.stringify(portalContent).replace(/</g, "\\u003c");
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "2-digit" }).format(date);
const dashboardStats = site.dashboard.stats.map((stat) =>
  stat.label === "Blog posts" ? { ...stat, value: String(blogPosts.length).padStart(2, "0") } : stat,
);
const categories = Array.from(new Set(blogPosts.map((post) => post.data.category).filter(Boolean)));
const tagCounts = blogPosts.reduce((counts, post) => {
  post.data.tags.forEach((tag) => counts.set(tag, (counts.get(tag) ?? 0) + 1));
  return counts;
}, new Map<string, number>());
const topTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 8);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={site.description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <title>{site.title}</title>
  </head>
  <body style={backgroundStyle} data-admin-api={adminApiUrl} data-portal-base={base}>
    <div class="backdrop" aria-hidden="true"></div>
    <div class="soft-wash" aria-hidden="true"></div>

    <header class="portal-header">
      <a class="portal-brand" href={withBase()} aria-label="Portal home">
        <span class="brand-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img">
            <path d="M12 2.8 20 6.2v5.9c0 4.8-3.4 7.8-8 9.1-4.6-1.3-8-4.3-8-9.1V6.2l8-3.4Z"></path>
            <path d="M8.4 10.4 12 7.8l3.6 2.6-1.4 4.2H9.8l-1.4-4.2Z"></path>
          </svg>
        </span>
        <span>{site.brand.name}</span>
      </a>

      <nav class="tabs" aria-label="Portal pages">
        {
          navigation.map((item, index) => (
            <button
              class={`tab ${index === 0 ? "is-active" : ""}`}
              type="button"
              data-page={index}
              data-navigation-tab
              data-navigation-id={item.id}
              data-navigation-locked={String(item.locked)}
            >
              {item.label}
            </button>
          ))
        }
        <button class="tool-button compact editor-entry" type="button" aria-label="Enter edit mode" data-editor-toggle hidden>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7h9"></path>
            <path d="M17 7h3"></path>
            <path d="M15 5v4"></path>
            <path d="M4 17h3"></path>
            <path d="M11 17h9"></path>
            <path d="M9 15v4"></path>
          </svg>
        </button>
      </nav>

      <div class="header-actions" aria-label="Header actions">
        <a class="search-pill" href={withBase("search/")} aria-label="Search blog">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m20 20-4.3-4.3"></path>
            <circle cx="10.8" cy="10.8" r="6.2"></circle>
          </svg>
          <span>Search blog</span>
        </a>
        <div class="lab-menu" data-lab-menu>
          <button
            class="tool-button dot-grid"
            type="button"
            aria-label="Open lab menu"
            aria-expanded="false"
            aria-controls="lab-menu-panel"
            data-lab-menu-toggle
          >
            <span></span><span></span><span></span>
            <span></span><span></span><span></span>
            <span></span><span></span><span></span>
          </button>
          <div class="lab-menu-panel" id="lab-menu-panel" aria-label="Lab menu" data-lab-menu-panel hidden>
            <div class="lab-menu-heading">
              <strong>{site.lab.eyebrow}</strong>
              <small>功能菜单</small>
            </div>
            <ul class="lab-menu-tree" aria-label="Lab features">
              {
                site.lab.items.map((item, index) => (
                  <li class="lab-tree-item" data-lab-tree-item>
                    <button
                      class="lab-tree-trigger"
                      type="button"
                      aria-expanded="false"
                      aria-controls={`lab-tree-branch-${index}`}
                      data-lab-tree-trigger
                    >
                      <span class="lab-tree-marker" aria-hidden="true"></span>
                      <span>{item}</span>
                      <span class="lab-tree-chevron" aria-hidden="true">›</span>
                    </button>
                    <div class="lab-tree-branch" id={`lab-tree-branch-${index}`} data-lab-tree-branch hidden>
                      <button class="lab-branch-back" type="button" data-lab-branch-back>
                        <span aria-hidden="true">‹</span>
                        <strong>{item}</strong>
                      </button>
                      <p>等待开发</p>
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
        <a class="tool-button" href={withBase("contact/")} aria-label="Open contact links">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5.4 6.2h13.2a2 2 0 0 1 2 2v6.5a2 2 0 0 1-2 2h-6.1l-4.1 3v-3h-3a2 2 0 0 1-2-2V8.2a2 2 0 0 1 2-2Z"></path>
            <path d="M8 10.3h8"></path>
            <path d="M8 13.2h5.6"></path>
          </svg>
        </a>
        <a class="tool-button" href={withBase("about/")} aria-label="Open profile">
          <span>{site.brand.initials}</span>
        </a>
      </div>
    </header>

    <main class="app-shell">
      <aside class="profile-column" aria-label="Profile panel">
        <section class="profile-card panel">
          <a class="avatar avatar-link" href={withBase("about/")} aria-label="Open about page">
            <img src={withBase("assets/profile-photo.jpg")} alt="String profile photo" loading="eager" />
          </a>
          <h1>{site.profile.name}</h1>
          <p>{site.profile.summary}</p>
          <div class="quick-links" aria-label="Quick links">
            {site.profile.links.map((link) => <a href={linkHref(link.href)}>{link.label}</a>)}
          </div>
        </section>

        <section class="mini-card panel">
          <div class="mini-title">
            <span></span>
            Notice
          </div>
          <p>{site.profile.notice}</p>
        </section>

        <section class="mini-card panel">
          <div class="mini-title">
            <span></span>
            Tags
          </div>
          <div class="tag-cloud">
            {site.profile.tags.map((tag) => <a href={linkHref(tagHref(tag))}>{tag}</a>)}
          </div>
        </section>
      </aside>

      <section class="content-stage panel" aria-live="polite">
        <div class="slide-track" data-track style={`--page-count: ${pageCount}`}>
          <article class="page is-current" data-panel="home" data-route="">
            <div class="page-heading">
              <p>{site.dashboard.eyebrow}</p>
              <h2>{site.dashboard.title}</h2>
            </div>
            <div class="summary-row">
              {
                dashboardStats.map((stat, index) => (
                  <div class={`stat tone-${["a", "b", "c", "d"][index % 4]}`}>
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </div>
                ))
              }
            </div>
            <div class="home-grid">
              <section class="focus-panel">
                <h3>{site.dashboard.focus.title}</h3>
                <p>{site.dashboard.focus.text}</p>
                <div class="progress-line">
                  <span style={`width: ${site.dashboard.focus.progress}%`}></span>
                </div>
              </section>
              <section class="todo-panel">
                <h3>Next edits</h3>
                <ul>
                  {site.dashboard.today.map((item) => <li>{item}</li>)}
                </ul>
              </section>
              <section class="music-panel" aria-label="Now playing">
                <div>
                  <span>Music</span>
                  <h3>Now playing</h3>
                </div>
                <iframe
                  title="NetEase Cloud Music player"
                  frameborder="0"
                  width="330"
                  height="86"
                  src="https://music.163.com/outchain/player?type=2&id=1909742217&auto=1&height=66"
                  loading="lazy"
                  allow="autoplay"
                ></iframe>
              </section>
            </div>
          </article>

          <article class="page" data-panel="blog" data-route="blog/" data-tab="1">
            <div class="page-heading">
              <p>{site.blog.eyebrow}</p>
              <h2>{site.blog.title}</h2>
            </div>
            <div class="blog-panel-grid">
              <section class="note-card blog-preview-card">
                <h3>Latest posts</h3>
                <div class="blog-preview-list">
                  {
                    blogPosts.slice(0, 4).map((post) => (
                      <a class="blog-preview-link" href={withBase(`blog/${post.id}/`)}>
                        <span>{formatDate(getPostDate(post))}{post.data.pinned ? " / Pinned" : ""}</span>
                        <strong>{post.data.title}</strong>
                        <small>{post.data.description}</small>
                      </a>
                    ))
                  }
                </div>
              </section>
              <section class="note-card pale blog-help-card">
                <h3>Blog tools</h3>
                <p>{site.blog.intro}</p>
                <nav class="blog-tools" aria-label="Blog tools">
                  {site.blog.actions.map((action) => <a class="tool-link" href={linkHref(action.href)}>{action.label}</a>)}
                </nav>
              </section>
            </div>
          </article>

          {
            managedNavigation.map((navigationItem) => (
              <article
                class="page managed-navigation-page"
                data-panel={navigationItem.id}
                data-route={`${navigationItem.slug}/`}
                data-tab={tabIndexByNavigationId.get(navigationItem.id)}
                data-navigation-panel
                data-navigation-id={navigationItem.id}
              >
                <div class="page-heading">
                  <p>Navigation</p>
                  <h2 data-navigation-title>{navigationItem.title}</h2>
                </div>
                <p class="page-intro" data-navigation-description>{navigationItem.description}</p>
                <ManagedCardGrid
                  blocks={navigationItem.blocks}
                  pages={portalContent.pages}
                  base={base}
                  navigationId={navigationItem.id}
                />
                {navigationItem.id === "archives" && (
                  <div class="metadata-row">
                    <a href={withBase("blog/")}>{categories.length || 0} categories</a>
                    <a href={withBase("blog/")}>{topTags.length || 0} active tags</a>
                    <a href={withBase("blog/archive/")}>{blogPosts.length} published posts</a>
                  </div>
                )}
              </article>
            ))
          }

          {
            portalContent.pages.map((managedPage) => (
              <article
                class="page detail-page managed-detail-page"
                data-panel={`managed-${managedPage.id}`}
                data-route={`${managedPage.route}/`}
                data-tab={tabIndexByNavigationId.get(managedPage.parentNavigationId)}
                data-managed-page
                data-page-id={managedPage.id}
              >
                <a
                  class="panel-back"
                  href={withBase(`${portalContent.navigation.find((item) => item.id === managedPage.parentNavigationId)?.slug || ""}/`)}
                  data-portal-route={`${portalContent.navigation.find((item) => item.id === managedPage.parentNavigationId)?.slug || ""}/`}
                >
                  Back to {portalContent.navigation.find((item) => item.id === managedPage.parentNavigationId)?.title || "dashboard"}
                </a>
                <header class="section-header">
                  <p>{portalContent.navigation.find((item) => item.id === managedPage.parentNavigationId)?.title || "Page"}</p>
                  <div><span class="section-badge" data-managed-page-badge>{managedPage.badge}</span></div>
                  <h1 data-managed-page-title>{managedPage.title}</h1>
                  <span data-managed-page-description>{managedPage.description}</span>
                </header>
                <RichContent blocks={managedPage.content} base={base} />
              </article>
            ))
          }

          {
            renderedBlogPosts.map(({ post, Content }) => (
              <article
                class="page detail-page article-panel"
                data-panel={`post-${post.id}`}
                data-route={`blog/${post.id}/`}
                data-tab="1"
              >
                <a class="panel-back" href={withBase("blog/")} data-portal-route="blog/">Back to blog panel</a>
                <header class="article-header">
                  <time datetime={getPostDate(post).toISOString()}>{formatDate(getPostDate(post))}</time>
                  <h1>{post.data.title}</h1>
                  <p>{post.data.description}</p>
                  <div class="article-meta">
                    {post.data.category && <a class="meta-pill" href={withBase("blog/")}>{post.data.category}</a>}
                    {post.data.pinned && <span class="meta-pill">Pinned</span>}
                  </div>
                  <div class="article-tags">
                    {post.data.tags.map((tag) => (
                      <a href={withBase(`blog/tag/${tag.toLowerCase().replace(/\s+/g, "-")}/`)}>#{tag}</a>
                    ))}
                  </div>
                </header>
                <div class="article-body">
                  <Content />
                </div>
              </article>
            ))
          }

          <article class="page detail-page" data-panel="search" data-route="search/" data-search-root data-search-url={withBase("search-data.json")} data-base={base}>
            <a class="panel-back" href={withBase()} data-portal-route="">Back to dashboard</a>
            <div class="page-heading">
              <p>Search</p>
              <h2>Search blog inside the portal.</h2>
            </div>
            <input class="search-box portal-search-box" id="portal-search-box" type="search" placeholder="Type keywords..." autocomplete="off" />
            <section class="search-results" id="portal-search-results" aria-live="polite"></section>
          </article>
        </div>
      </section>
    </main>

    <aside class="editor-toolbar" data-editor-toolbar hidden aria-label="Edit controls">
      <div class="editor-toolbar-state">
        <span class="editor-live-dot" aria-hidden="true"></span>
        <strong>Edit mode</strong>
        <small data-editor-status>Draft loaded</small>
      </div>
      <div class="editor-toolbar-actions">
        <button type="button" class="editor-button" data-add-navigation>Add navigation</button>
        <button type="button" class="editor-button" data-add-card>Add block</button>
        <button type="button" class="editor-button" data-preview-draft>Preview</button>
        <button type="button" class="editor-button" data-release-history>Releases</button>
        <button type="button" class="editor-button editor-button--primary" data-publish-draft>Publish</button>
        <button type="button" class="editor-icon-button" data-exit-editor aria-label="Exit edit mode">×</button>
      </div>
    </aside>

    <dialog class="editor-dialog" data-navigation-dialog>
      <form class="editor-form" data-navigation-form>
        <header>
          <div>
            <small>Navigation</small>
            <h2 data-navigation-dialog-title>Add navigation</h2>
          </div>
          <button type="button" class="editor-icon-button" data-close-dialog aria-label="Close">×</button>
        </header>
        <input type="hidden" name="navigationId" />
        <label>
          Page title
          <input name="title" maxlength="60" required placeholder="Article" />
        </label>
        <label>
          Navigation label
          <input name="label" maxlength="18" required placeholder="ARTICLE" />
        </label>
        <label>
          Page address
          <span class="editor-input-prefix">/ <input name="slug" maxlength="64" required placeholder="article" /> /</span>
        </label>
        <label>
          Description
          <textarea name="description" maxlength="240" rows="3" required placeholder="What this section contains."></textarea>
        </label>
        <footer>
          <button type="button" class="editor-button" data-close-dialog>Cancel</button>
          <button type="submit" class="editor-button editor-button--primary">Save navigation</button>
        </footer>
      </form>
    </dialog>

    <dialog class="editor-dialog" data-card-dialog>
      <form class="editor-form" data-card-form>
        <header>
          <div>
            <small>Block</small>
            <h2 data-card-dialog-title>Add block</h2>
          </div>
          <button type="button" class="editor-icon-button" data-close-dialog aria-label="Close">×</button>
        </header>
        <input type="hidden" name="navigationId" />
        <input type="hidden" name="cardId" />
        <div class="editor-field-row">
          <label>
            Block type
            <select name="type">
              <option value="text">Information block</option>
              <option value="page">Page block</option>
            </select>
          </label>
          <label>
            Width
            <select name="width">
              <option value="half">Half width</option>
              <option value="full">Full row</option>
            </select>
          </label>
        </div>
        <label>
          Badge
          <input name="badge" maxlength="4" required placeholder="AR" />
        </label>
        <label>
          Title
          <input name="title" maxlength="80" required placeholder="Article" />
        </label>
        <label>
          Summary
          <textarea name="summary" maxlength="320" rows="3" required placeholder="A short description shown on the block."></textarea>
        </label>
        <div class="editor-field-row">
          <label>
            Image URL <small>(optional)</small>
            <input name="imageSrc" type="url" placeholder="https://…" />
          </label>
          <label>
            Upload image <small>(JPG, PNG, WebP · 10 MB)</small>
            <input name="imageFile" type="file" accept="image/jpeg,image/png,image/webp" />
          </label>
        </div>
        <div class="editor-field-row">
          <label>
            Image alt text
            <input name="imageAlt" maxlength="160" placeholder="Describe the image" />
          </label>
          <label>
            Image caption
            <input name="imageCaption" maxlength="180" placeholder="Optional caption" />
          </label>
        </div>
        <div data-page-card-fields hidden>
          <label>
            Destination
            <select name="destinationKind">
              <option value="new-page">Create a new page</option>
              <option value="url">Open an existing URL</option>
            </select>
          </label>
          <label data-card-url-field hidden>
            URL
            <input name="destinationUrl" placeholder="https://… or /path/" />
          </label>
        </div>
        <div class="editor-field-row" data-text-card-fields>
          <label>
            Link button label <small>(optional)</small>
            <input name="actionLabel" maxlength="40" placeholder="Open resource" />
          </label>
          <label>
            Link button URL
            <input name="actionHref" placeholder="https://… or /path/" />
          </label>
        </div>
        <footer>
          <button type="button" class="editor-button" data-close-dialog>Cancel</button>
          <button type="submit" class="editor-button editor-button--primary">Save block</button>
        </footer>
      </form>
    </dialog>

    <dialog class="editor-dialog editor-dialog--danger" data-delete-dialog>
      <form class="editor-form" data-delete-form>
        <header>
          <div>
            <small>Permanent deletion</small>
            <h2 data-delete-title>Delete item</h2>
          </div>
          <button type="button" class="editor-icon-button" data-close-dialog aria-label="Close">×</button>
        </header>
        <p data-delete-summary></p>
        <dl class="editor-impact-list" data-delete-impact></dl>
        <label data-delete-confirm-field hidden>
          Type <strong data-delete-confirm-name></strong> to confirm
          <input name="confirmation" autocomplete="off" />
        </label>
        <footer>
          <button type="button" class="editor-button" data-close-dialog>Cancel</button>
          <button type="submit" class="editor-button editor-button--danger" data-confirm-delete>Delete permanently</button>
        </footer>
      </form>
    </dialog>

    <dialog class="editor-dialog" data-releases-dialog>
      <section class="editor-form">
        <header>
          <div>
            <small>Published versions</small>
            <h2>Release history</h2>
          </div>
          <button type="button" class="editor-icon-button" data-close-dialog aria-label="Close">×</button>
        </header>
        <p>Up to 20 content releases are shown. Restoring creates a new commit and keeps the existing history.</p>
        <div class="editor-release-list" data-release-list aria-live="polite">
          <p>Loading releases...</p>
        </div>
        <footer>
          <button type="button" class="editor-button" data-close-dialog>Close</button>
        </footer>
      </section>
    </dialog>

    <section class="page-editor" data-page-editor hidden aria-label="Page content editor">
      <header class="page-editor-header">
        <button type="button" class="editor-button" data-close-page-editor>← Back</button>
        <div>
          <small>Page editor</small>
          <strong data-page-editor-title>Untitled page</strong>
        </div>
        <div class="page-editor-header-actions">
          <button type="button" class="editor-button" data-page-editor-preview>Preview</button>
          <button type="button" class="editor-button editor-button--primary" data-close-page-editor>Save draft</button>
        </div>
      </header>
      <div class="page-editor-layout">
        <aside class="page-editor-palette" aria-label="Content blocks">
          <strong>Add content</strong>
          <button type="button" data-add-rich-block="paragraph">Paragraph</button>
          <button type="button" data-add-rich-block="heading">Heading</button>
          <button type="button" data-add-rich-block="image">Image</button>
          <button type="button" data-add-rich-block="list">List</button>
          <button type="button" data-add-rich-block="link">Link button</button>
          <button type="button" data-add-rich-block="quote">Quote</button>
          <button type="button" data-add-rich-block="divider">Divider</button>
          <button type="button" data-add-rich-block="code">Code</button>
        </aside>
        <div class="page-editor-canvas" data-page-editor-canvas></div>
        <aside class="page-editor-preview" data-page-editor-preview-pane aria-label="Page preview"></aside>
      </div>
    </section>

    <div class="editor-toast" data-editor-toast hidden role="status"></div>
    <script id="portal-content-data" type="application/json" set:html={serializedPortalContent}></script>

    <script is:inline>
      const track = document.querySelector("[data-track]");
      const basePath = new URL(document.baseURI).pathname;
      let tabs = [];
      let panels = [];
      let pageCount = 1;
      let routeMap = new Map();

      function refreshPortalRouting() {
        tabs = Array.from(document.querySelectorAll("[data-page]"));
        panels = Array.from(document.querySelectorAll("[data-panel]"));
        pageCount = panels.length || 1;
        routeMap = new Map();
        track.style.setProperty("--page-count", String(pageCount));
        panels.forEach((panel, index) => {
          panel.dataset.panelIndex = String(index);
          const route = panel.dataset.route;
          if (route !== undefined) routeMap.set(route, panel.dataset.panel);
        });
        routeMap.set("/", "home");
        routeMap.set("", "home");
      }

      refreshPortalRouting();

      function normalizeRoute(url) {
        const parsed = new URL(url, window.location.href);
        if (parsed.origin !== window.location.origin) return null;
        let pathname = parsed.pathname;
        if (basePath !== "/" && pathname.startsWith(basePath)) {
          pathname = pathname.slice(basePath.length);
        }
        pathname = pathname.replace(/^\/+/, "");
        return pathname ? `${pathname.replace(/\/?$/, "/")}${parsed.search}` : "";
      }

      function setActivePage(index, pushRoute = null) {
        const pageIndex = Number(index);
        track.style.transform = `translateX(calc(-${pageIndex} * 100% / ${pageCount}))`;

        const activePanel = panels[pageIndex];
        const activeTab = activePanel?.dataset.tab ? Number(activePanel.dataset.tab) : pageIndex;

        tabs.forEach((tab, currentIndex) => {
          const isActive = currentIndex === activeTab;
          tab.classList.toggle("is-active", isActive);
          tab.setAttribute("aria-selected", String(isActive));
        });

        panels.forEach((panel, currentIndex) => {
          panel.classList.toggle("is-current", currentIndex === pageIndex);
        });

        if (pushRoute !== null) {
          const routeUrl = new URL(pushRoute || ".", window.location.origin + basePath);
          window.history.pushState({ panel: activePanel?.dataset.panel }, "", routeUrl);
        }
      }

      function openPanel(panelName, pushRoute = null) {
        const panel = panels.find((item) => item.dataset.panel === panelName);
        if (!panel) return false;
        setActivePage(Number(panel.dataset.panelIndex), pushRoute);
        return true;
      }

      function openRoute(route, push = true) {
        const cleanRoute = route.split("?")[0];
        const panelName = routeMap.get(cleanRoute);
        if (!panelName) return false;
        return openPanel(panelName, push ? cleanRoute : null);
      }

      const labMenu = document.querySelector("[data-lab-menu]");
      const labMenuToggle = labMenu?.querySelector("[data-lab-menu-toggle]");
      const labMenuPanel = labMenu?.querySelector("[data-lab-menu-panel]");
      const labTreeTriggers = Array.from(labMenu?.querySelectorAll("[data-lab-tree-trigger]") || []);
      const labBranchBacks = Array.from(labMenu?.querySelectorAll("[data-lab-branch-back]") || []);
      const labLayerTimers = new WeakMap();
      const labReduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      function clearLabLayerTimer(layer) {
        const timer = labLayerTimers.get(layer);
        if (timer) window.clearTimeout(timer);
        labLayerTimers.delete(layer);
      }

      function showLabLayer(layer) {
        if (!layer) return;
        clearLabLayerTimer(layer);
        layer.hidden = false;
        layer.dataset.state = "opening";
        if (labReduceMotion) {
          layer.dataset.state = "open";
          return;
        }
        layer.getBoundingClientRect();
        layer.dataset.state = "open";
      }

      function hideLabLayer(layer) {
        if (!layer || layer.hidden || layer.dataset.state === "closing") return;
        clearLabLayerTimer(layer);
        layer.dataset.state = "closing";
        const finish = () => {
          if (layer.dataset.state !== "closing") return;
          layer.hidden = true;
          layer.removeAttribute("data-state");
          labLayerTimers.delete(layer);
        };
        if (labReduceMotion) {
          finish();
          return;
        }
        labLayerTimers.set(layer, window.setTimeout(finish, 240));
      }

      function collapseLabBranches(exceptTrigger = null) {
        labTreeTriggers.forEach((trigger) => {
          if (trigger === exceptTrigger) return;
          trigger.setAttribute("aria-expanded", "false");
          const branchId = trigger.getAttribute("aria-controls");
          const branch = branchId ? document.getElementById(branchId) : null;
          hideLabLayer(branch);
        });
      }

      function setLabMenuOpen(open, returnFocus = false) {
        if (!labMenuToggle || !labMenuPanel) return;
        labMenuToggle.setAttribute("aria-expanded", String(open));
        labMenu.classList.toggle("is-open", open);
        if (open) showLabLayer(labMenuPanel);
        else hideLabLayer(labMenuPanel);
        if (!open) {
          collapseLabBranches();
          if (returnFocus) labMenuToggle.focus();
        }
      }

      labMenuToggle?.addEventListener("click", () => {
        setLabMenuOpen(labMenuToggle.getAttribute("aria-expanded") !== "true");
      });

      labTreeTriggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const willOpen = trigger.getAttribute("aria-expanded") !== "true";
          collapseLabBranches(trigger);
          trigger.setAttribute("aria-expanded", String(willOpen));
          const branchId = trigger.getAttribute("aria-controls");
          const branch = branchId ? document.getElementById(branchId) : null;
          if (willOpen) showLabLayer(branch);
          else hideLabLayer(branch);
        });
      });

      labBranchBacks.forEach((backButton) => {
        backButton.addEventListener("click", () => {
          const branch = backButton.closest("[data-lab-tree-branch]");
          const trigger = branch?.id
            ? labTreeTriggers.find((item) => item.getAttribute("aria-controls") === branch.id)
            : null;
          hideLabLayer(branch);
          if (trigger) {
            trigger.setAttribute("aria-expanded", "false");
            trigger.focus();
          }
        });
      });

      document.addEventListener("click", (event) => {
        if (labMenu && !labMenu.contains(event.target)) {
          setLabMenuOpen(false);
        }

        const tab = event.target.closest("[data-page]");
        if (tab) {
          setActivePage(tab.dataset.page, null);
          return;
        }

        const link = event.target.closest("a[href]");
        if (!link || link.target || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

        const route = link.dataset.portalRoute ?? normalizeRoute(link.href);
        if (route === null) return;
        if (openRoute(route)) {
          event.preventDefault();
          setLabMenuOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && labMenuToggle?.getAttribute("aria-expanded") === "true") {
          const expandedTrigger = labTreeTriggers.find((trigger) => trigger.getAttribute("aria-expanded") === "true");
          if (expandedTrigger) {
            collapseLabBranches();
            expandedTrigger.focus();
          } else {
            setLabMenuOpen(false, true);
          }
        }
      });

      window.addEventListener("popstate", () => {
        const route = normalizeRoute(window.location.href);
        if (!route || !openRoute(route, false)) {
          setActivePage(0);
        }
      });

      const searchRoot = document.querySelector("[data-search-root]");
      const searchInput = document.getElementById("portal-search-box");
      const searchResults = document.getElementById("portal-search-results");
      const searchUrl = searchRoot?.dataset.searchUrl || `${basePath}search-data.json`;
      let portalPosts = [];

      const withPortalBase = (path) => `${basePath}${String(path).replace(/^\/+/, "")}`;
      const normalizeText = (value) => String(value || "").toLowerCase();

      function findPortalMatches(query) {
        const terms = normalizeText(query).trim().split(/\s+/).filter(Boolean);
        if (terms.length === 0) return [];

        return portalPosts.filter((post) => {
          const haystack = normalizeText([
            post.title,
            post.description,
            post.category,
            ...(post.tags || []),
            post.excerpt,
          ].join(" "));
          return terms.every((term) => haystack.includes(term));
        });
      }

      function renderPortalSearch(items, query) {
        searchResults?.replaceChildren();
        if (!searchResults) return;

        if (!query) {
          const empty = document.createElement("p");
          empty.className = "search-empty";
          empty.textContent = "Type keywords to search matching posts.";
          searchResults.appendChild(empty);
          return;
        }

        if (items.length === 0) {
          const empty = document.createElement("p");
          empty.className = "search-empty";
          empty.textContent = "No matching posts found yet.";
          searchResults.appendChild(empty);
          return;
        }

        items.forEach((post) => {
          const card = document.createElement("article");
          card.className = "search-result-card";

          const title = document.createElement("a");
          title.className = "post-title-link";
          title.href = withPortalBase(post.url);
          title.textContent = post.title;

          const meta = document.createElement("small");
          meta.textContent = `${post.category} / ${post.reading}`;

          const desc = document.createElement("p");
          desc.textContent = post.description || post.excerpt || "";

          card.append(title, meta, desc);
          searchResults.appendChild(card);
        });
      }

      function runPortalSearch(query) {
        renderPortalSearch(findPortalMatches(query), query.trim());
      }

      fetch(searchUrl)
        .then((response) => response.json())
        .then((data) => {
          portalPosts = Array.isArray(data) ? data : [];
          runPortalSearch("");
        })
        .catch(() => {
          if (searchResults) searchResults.textContent = "Search index failed to load.";
        });

      searchInput?.addEventListener("input", () => {
        runPortalSearch(searchInput.value);
      });

      setActivePage(0);
      window.portalRouter = { refresh: refreshPortalRouting, openPanel, openRoute, setActivePage };
    </script>
    <script type="module" src={editorScriptUrl}></script>
  </body>
</html>
